# Database
DATABASE_URL=mysql+pymysql://root:@localhost:3306/dts_ai_engine

# DTS Backend API
DTS_API_BASE_URL=http://localhost:8080
DTS_MOCK_MODE=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000

# Production: run with multiple workers and NO --reload
# uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4
#
# Rate limits (per IP):
#   /api/chat  → 30 req/min
#   /api/tts   → 20 req/min
#   /api/train → 5 req/min
